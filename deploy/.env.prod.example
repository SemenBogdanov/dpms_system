DB_SCHEMA=
DPMS_SECRET_KEY=<run: openssl rand -hex 32>
APP_TITLE=DPMS API
APP_VERSION=1.0.0
DEBUG=false
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=https://your-domain.ru,http://localhost:5173
UPLOAD_DIR=/app/uploads
